# Your Google OAuth Client ID from Google Cloud Console
# Get it from: https://console.cloud.google.com/ → APIs & Services → Credentials
GOOGLE_CLIENT_ID= google_client_id_placeholder

# Your Extension Key (base64 public key derived from dist.pem)
# Steps: Pack extension in chrome://extensions → then run:
# openssl rsa -in dist.pem -pubout -outform DER | openssl base64 -A
GOOGLE_EXTENSION_KEY= google_extension_key_placeholder