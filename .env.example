# Copy this file to .env.local and fill in your values

# Get your Client ID from Google Cloud Console:
# https://console.cloud.google.com/ → APIs & Services → Credentials → Create OAuth Client ID (Chrome Extension)
GOOGLE_CLIENT_ID=your_client_id_here.apps.googleusercontent.com

# Get your Extension Key by packing the extension in chrome://extensions, then run:
# openssl rsa -in dist.pem -pubout -outform DER | openssl base64 -A
GOOGLE_EXTENSION_KEY=your_extension_key_here
